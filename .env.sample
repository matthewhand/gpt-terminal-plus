# ─── Required ────────────────────────────────────────────────────────────────
# Bearer token for all protected endpoints. Generate with: openssl rand -base64 48
# If unset, a token is generated at startup and printed to the console.
API_TOKEN=your_secure_api_token

# ─── Core server ─────────────────────────────────────────────────────────────
PORT=5005
NODE_ENV=                       # e.g. production — selects config/<env>.json
NODE_CONFIG_DIR=./config        # read/write; persistent config storage
DEBUG=                          # e.g. app:* for debug logging
SUPPRESS_NO_CONFIG_WARNING=     # true to silence node-config warnings

# Public URL advertised in OpenAPI servers[0].url (set when behind a proxy)
PUBLIC_BASE_URL=                # e.g. https://your-domain.example.com
PUBLIC_HOST=localhost           # used to derive URL if PUBLIC_BASE_URL unset

# CORS allowed origins (comma-separated)
CORS_ORIGIN=https://chat.openai.com,https://chatgpt.com

# HTTPS (if not terminating TLS at a reverse proxy)
HTTPS_ENABLED=                  # true
HTTPS_KEY_PATH=                 # path/to/private.key
HTTPS_CERT_PATH=                # path/to/certificate.crt

DISABLE_HEALTH_LOG=             # true to suppress /health request logs
SSE_HEARTBEAT_MS=15000          # SSE heartbeat interval for streaming routes
USE_SERVERLESS=                 # true to export a serverless-http handler

# ─── Feature toggles ─────────────────────────────────────────────────────────
ENABLE_CODE_EXECUTION=true      # enable /command/execute-code
ENABLE_COMMAND_MANAGEMENT=      # false to disable command management routes
USE_MCP=                        # true to mount the (experimental) MCP endpoint

# ─── Command execution & safety ──────────────────────────────────────────────
DEFAULT_SHELL=                  # e.g. bash
SHELL_ALLOWED=                  # comma-separated allowlist of shells
EXECUTE_TIMEOUT_MS=             # per-execution timeout in ms
DEFAULT_TIMEOUT=                # default handler timeout in ms
USE_EXECFILE=                   # true to use execFile instead of shell exec
DENY_COMMAND_REGEX=             # comma-separated regex patterns to block
CONFIRM_COMMAND_REGEX=          # comma-separated regex patterns requiring confirm

# ─── Remote targets ──────────────────────────────────────────────────────────
SERVERS_CONFIG_PATH=            # path to servers JSON (default under data/)
SSM_RETRIES=                    # AWS SSM result polling retries
SSM_WAIT_TIME=                  # AWS SSM wait between polls (ms)

# ─── LLM / AI providers (optional) ───────────────────────────────────────────
AI_PROVIDER=                    # ollama | lmstudio | openai | open-interpreter | auto
DEFAULT_MODEL=                  # e.g. gpt-oss:20b
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=your_openai_api_key
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234
AUTO_ANALYZE_ERRORS=true        # run AI analysis on failed executions

# LLM settings (override stored settings)
LLM_ENABLED=false               # true to enable LLM features
LLM_PROVIDER=none               # none | openai | ollama | lmstudio | litellm
LLM_DEFAULT_MODEL=
LLM_MODEL=
OLLAMA_URL=http://localhost:11434
OLLAMA_HOST=
LM_STUDIO_URL=http://localhost:1234/v1

# Open Interpreter compat (legacy)
INTERPRETER_SERVER_HOST=
INTERPRETER_SERVER_PORT=
INTERPRETER_OFFLINE=            # false
INTERPRETER_VERBOSE=            # true

# ─── Misc ────────────────────────────────────────────────────────────────────
GTP_SETTINGS_PATH=              # path to persisted settings JSON
NGROK_ENABLED=                  # true to open an ngrok tunnel at startup
NGROK_PORT=5005
NGROK_AUTHTOKEN=your_ngrok_authtoken
